# .env.example — TechCorp RAG Application
#
# Copy this file to .env and fill in your real values.
# NEVER commit the .env file to version control.
# Add ".env" to your .gitignore before running this project.

# ------------------------------------------------------------------
# AWS Credentials
# ------------------------------------------------------------------
# AWS Console → IAM → Users → your user → Security credentials → Create access key

AWS_ACCESS_KEY_ID=your_access_key_id_here
AWS_SECRET_ACCESS_KEY=your_secret_access_key_here

# AWS region for all resources (S3 bucket, Bedrock Knowledge Base).
# Common values: us-east-1 | us-west-2 | eu-west-2 | ap-southeast-1
AWS_REGION=us-east-1

# ------------------------------------------------------------------
# S3 Bucket (populated by aws_setup.py)
# ------------------------------------------------------------------
# After running:  python aws_setup.py
# paste the printed bucket name here.

S3_BUCKET_NAME=

# ------------------------------------------------------------------
# Amazon Bedrock Knowledge Base
# ------------------------------------------------------------------
# Step 1 — In the AWS Console go to:
#   Amazon Bedrock → Knowledge Bases → Create knowledge base
#   Point the data source at the S3 bucket above.
#
# Step 2 — Paste the Knowledge Base ID (looks like: ABCDE12345)
KNOWLEDGE_BASE_ID=

# Step 3 — Set the model. Accepts EITHER a full ARN or a plain model ID.
# app.py will automatically expand a model ID into the required ARN format.
#
# ⚠ Claude 3.5+ and Claude 4.x require a cross-region inference profile.
#   Add the regional prefix "us.", "eu.", or "ap." before "anthropic." in the ID.
#
# Option A — plain model ID (simplest):
#   MODEL_ARN=us.anthropic.claude-haiku-4-5-20251001-v1:0
#
# Option B — full ARN (if you prefer to be explicit):
#   MODEL_ARN=arn:aws:bedrock:us-east-1::foundation-model/us.anthropic.claude-haiku-4-5-20251001-v1:0
#
# Common model IDs by region prefix:
#   us.anthropic.claude-haiku-4-5-20251001-v1:0      (US — cheapest / fastest)
#   us.anthropic.claude-sonnet-4-5-20251101-v1:0     (US — balanced)
#   eu.anthropic.claude-haiku-4-5-20251001-v1:0      (EU)
#   ap.anthropic.claude-haiku-4-5-20251001-v1:0      (APAC)
MODEL_ARN=
